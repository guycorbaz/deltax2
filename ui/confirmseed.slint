// Confirm Seed Screen
// Step 2 of the seeding flow: Asks the user to load seeds into the hopper/robot
// before starting the automated process.

import { Button } from "std-widgets.slint";

export component ConfirmSeed inherits Rectangle {
    background: #c2c2c2;

    // Callbacks for navigation.
    callback cancel-clicked(); // Return to home screen
    callback ok-clicked();     // Final confirmation, start seeding process

    // Instruction Title
    Text {
        text: @tr("Load the seeds");
        y: 30px;
        font-size: 20px;
        font-weight: 700;
        horizontal-alignment: center;
        width: parent.width;
    }

    // Reference image of seeds
    Image {
        width: 250px;
        x: parent.width - self.width - 20px;
        y: (parent.height - self.height) / 2;
        source: @image-url("assets/images/graines.png");
    }

    // --- Action Buttons ---
    // Positioned absolutely (not in a HorizontalBox): a layout with an explicit
    // `y` but no explicit height fills the parent, which pushed these buttons
    // away from the bottom. Plain 60px buttons anchored to `parent.height` sit
    // at the bottom, consistent with every other screen's footer.
    // The pair (160 + 30 gap + 160 = 350) is centered horizontally.
    Button {
        x: (parent.width - 350px) / 2;
        y: parent.height - self.height - 15px;
        width: 160px;
        height: 60px;
        text: @tr("Cancel");
        icon: @image-url("assets/icons/close.svg");
        clicked => {
            root.cancel-clicked()
        }
    }

    Button {
        x: (parent.width - 350px) / 2 + 190px;
        y: parent.height - self.height - 15px;
        width: 160px;
        height: 60px;
        text: @tr("Ok");
        clicked => {
            root.ok-clicked()
        }
    }
}
