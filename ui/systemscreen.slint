// System Configuration Screen
// Serial port management for the touch-only kiosk: shows the detected ports
// on screen (stdout is invisible in production), lets the operator pick one,
// and re-runs the connect handshake from the UI (issue #4).

import { AppButton } from "widgets.slint";
import { Theme } from "theme.slint";

export component SystemScreen inherits Rectangle {
    background: Theme.bg;

    // Detected serial ports (always includes the configured port), the
    // currently picked port, and the live connection state — all driven by
    // the backend through AppWindow.
    in property <[string]> com-ports;
    in-out property <string> selected-port;
    in property <bool> is-connected;
    in property <string> status-text;

    // Callbacks to the application/backend.
    callback ok-clicked();        // Return to home screen
    callback refresh-clicked();   // Re-enumerate the serial ports
    callback reconnect-clicked(); // Re-run the connect handshake on selected-port

    // Title label
    Text {
        text: @tr("Serial connection");
        y: 20px;
        font-size: Theme.font-title;
        font-weight: 700;
        color: Theme.text;
        horizontal-alignment: center;
        width: parent.width;
    }

    // Connection state + currently selected port. status-text carries the
    // pending "Connecting..." feedback while a reconnect is in flight.
    HorizontalLayout {
        x: 20px;
        y: 64px;
        spacing: 10px;
        Rectangle {
            width: 14px;
            height: 14px;
            border-radius: 7px;
            background: root.is-connected ? Theme.ok : Theme.danger;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: root.status-text;
            font-size: Theme.font-body;
            color: Theme.text;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    // Port selection list. Enumeration is degraded on Linux (no libudev), so
    // the list is short in practice; the configured port is always present.
    Text {
        text: @tr("Detected ports:");
        x: 20px;
        y: 104px;
        font-size: Theme.font-body;
        font-weight: 700;
        color: Theme.text-muted;
    }
    // Bounded to 208px and clipped so a long port list can never spill over
    // the footer within the 440px content area (enumeration is degraded on
    // Linux, so the list is 1-2 entries in practice).
    Rectangle {
        x: 20px;
        y: 132px;
        width: 380px;
        height: 208px;
        clip: true;

        VerticalLayout {
            spacing: 10px;
            alignment: start;
            for port in root.com-ports: Rectangle {
                height: 60px;
                border-radius: Theme.radius-s;
                border-width: port == root.selected-port ? 2px : 1px;
                border-color: port == root.selected-port ? Theme.accent : Theme.border;
                background: port == root.selected-port ? Theme.accent-soft : Theme.surface;
                Text {
                    text: port;
                    font-size: Theme.font-heading;
                    color: Theme.text;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    overflow: elide;
                }
                TouchArea {
                    clicked => {
                        root.selected-port = port;
                    }
                }
            }
        }
    }

    // Action column on the right: Refresh the list, Reconnect (primary),
    // and Ok to leave. All ≥60px for gloved touch.
    AppButton {
        x: 440px;
        y: 132px;
        width: 200px;
        height: 60px;
        text: @tr("Refresh ports");
        icon: @image-url("assets/icons/settings-2.svg");
        clicked => {
            root.refresh-clicked()
        }
    }
    AppButton {
        x: 440px;
        y: 202px;
        width: 200px;
        height: 60px;
        primary: true;
        enabled: root.selected-port != "";
        text: @tr("Reconnect");
        clicked => {
            root.reconnect-clicked()
        }
    }

    // Navigation Footer — anchored to the bottom-right corner, the shared
    // position for a screen's confirm/leave button.
    AppButton {
        x: parent.width - self.width - 20px;
        y: parent.height - self.height - 15px;
        width: 160px;
        height: 60px;
        primary: true;
        text: @tr("Ok");
        clicked => {
            root.ok-clicked()
        }
    }
}
