// Calibration Screen
// This screen allows the user to manually control the robot's movement (jogging)
// and perform homing operations for all axes.
//
// Layout note: the usable content area is 800x440 (the 40px status bar sits
// below it), so every section is positioned to fit within 440px height with a
// clear gap above the footer. All buttons are 60px tall.

import { AppButton } from "widgets.slint";
import { Theme } from "theme.slint";

export component CalibrationScreen inherits Rectangle {
    background: Theme.bg;

    // Head position properties received from the backend (for display only).
    in-out property <string> head-x: "0.000";
    in-out property <string> head-y: "0.000";
    in-out property <string> head-z: "0.000";
    in-out property <string> head-cart: "0.000";

    // The amount the robot moves on each button click.
    in-out property <float> step-size: 0.01;

    // True while a jog/homing command is running on the worker. Motion buttons
    // disable themselves so taps cannot pile up faster than the robot executes
    // them (issue #13); the step-size and Ok buttons stay usable.
    in property <bool> busy;

    // Callbacks to notify the Rust backend of user interactions.
    callback ok-clicked();
    callback move-x(float);
    callback move-y(float);
    callback move-z(float);
    callback move-cart(float);
    callback home-xyz();
    callback home-cart();

    // --- Position Readout Section (Top Right) ---
    Rectangle {
        x: 421px;
        y: 8px;
        width: 349px;
        height: 75px;
        Text {
            text: @tr("Position");
            y: 0px;
            width: parent.width;
            font-size: Theme.font-small;
            font-weight: 700;
            color: Theme.text-muted;
            horizontal-alignment: center;
        }

        Rectangle {
            y: 20px;
            width: parent.width;
            height: 50px;
            background: Theme.surface;
            border-color: Theme.border;
            border-width: 1px;
            border-radius: Theme.radius-s;
            Text {
                text: "X: " + root.head-x + "   Y: " + root.head-y + "   Z: " + root.head-z + "   Cart: " + root.head-cart;
                vertical-alignment: center;
                horizontal-alignment: center;
                color: Theme.text;
                font-weight: 700;
            }
        }
    }

    // --- Step Size Selection Section (Above XY Controls) ---
    Rectangle {
        x: 80px;
        y: 8px;
        width: 280px;
        height: 84px;
        Text {
            text: @tr("Step (mm)");
            y: 0px;
            width: parent.width;
            font-size: Theme.font-small;
            font-weight: 700;
            color: Theme.text-muted;
            horizontal-alignment: center;
        }

        // The active step is filled (primary/accent) so the operator can tell
        // whether the next jog moves 0.01mm or 5mm (#16).
        AppButton {
            x: 0px;
            y: 22px;
            width: 60px;
            height: 60px;
            text: "0.01";
            primary: root.step-size == 0.01;
            clicked => {
                root.step-size = 0.01;
            }
        }

        AppButton {
            x: 73px;
            y: 22px;
            width: 60px;
            height: 60px;
            text: "0.1";
            primary: root.step-size == 0.1;
            clicked => {
                root.step-size = 0.1;
            }
        }

        AppButton {
            x: 146px;
            y: 22px;
            width: 60px;
            height: 60px;
            text: "1";
            primary: root.step-size == 1.0;
            clicked => {
                root.step-size = 1.0;
            }
        }

        AppButton {
            x: 219px;
            y: 22px;
            width: 60px;
            height: 60px;
            text: "5";
            primary: root.step-size == 5.0;
            clicked => {
                root.step-size = 5.0;
            }
        }
    }

    // --- Axis labels (above their pads) ---
    Text {
        x: 80px + (280px - self.width) / 2;
        y: 94px;
        text: "Y";
        font-size: Theme.font-small;
        font-weight: 700;
        color: Theme.text-muted;
    }

    Text {
        x: 80px - self.width - 10px;
        y: 116px + (232px - self.height) / 2;
        text: "X";
        font-size: Theme.font-small;
        font-weight: 700;
        color: Theme.text-muted;
    }

    Text {
        x: 437px + (110px - self.width) / 2;
        y: 94px;
        text: "Z";
        font-size: Theme.font-small;
        font-weight: 700;
        color: Theme.text-muted;
    }

    Text {
        x: 610px + (110px - self.width) / 2;
        y: 94px;
        text: "Cart";
        font-size: Theme.font-small;
        font-weight: 700;
        color: Theme.text-muted;
    }

    // --- XY Controller Section ---
    Rectangle {
        x: 80px;
        y: 116px;
        width: 280px;
        height: 232px;
        background: Theme.surface;
        border-color: Theme.border;
        border-width: 1px;
        border-radius: Theme.radius;
        AppButton {
            x: (parent.width - self.width) / 2;
            y: 12px;
            width: 60px;
            height: 60px;
            icon: @image-url("assets/icons/arrow-up.svg");
            enabled: !root.busy;
            clicked => {
                root.move-y(root.step-size)
            }
        }

        AppButton {
            x: 10px;
            y: (parent.height - self.height) / 2;
            width: 60px;
            height: 60px;
            icon: @image-url("assets/icons/arrow-left.svg");
            enabled: !root.busy;
            clicked => {
                root.move-x(-root.step-size)
            }
        }

        // Center is intentionally empty: homing is global (G28) and lives in a
        // clearly labeled footer button, not inside a single-axis pad (#16).
        // It doubles as the "move in progress" indicator (issue #13).
        Text {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            text: @tr("Moving…");
            color: Theme.warning-text;
            font-size: Theme.font-small;
            font-weight: 700;
            visible: root.busy;
        }

        AppButton {
            x: parent.width - self.width - 10px;
            y: (parent.height - self.height) / 2;
            width: 60px;
            height: 60px;
            icon: @image-url("assets/icons/arrow-right.svg");
            enabled: !root.busy;
            clicked => {
                root.move-x(root.step-size)
            }
        }

        AppButton {
            x: (parent.width - self.width) / 2;
            y: parent.height - self.height - 12px;
            width: 60px;
            height: 60px;
            icon: @image-url("assets/icons/arrow-down.svg");
            enabled: !root.busy;
            clicked => {
                root.move-y(-root.step-size)
            }
        }
    }

    // --- Z Axis Controller Section ---
    Rectangle {
        x: 437px;
        y: 116px;
        width: 110px;
        height: 232px;
        background: Theme.surface;
        border-color: Theme.border;
        border-width: 1px;
        border-radius: Theme.radius;
        AppButton {
            x: (parent.width - self.width) / 2;
            y: 12px;
            width: 60px;
            height: 60px;
            icon: @image-url("assets/icons/arrow-up.svg");
            enabled: !root.busy;
            clicked => {
                root.move-z(root.step-size)
            }
        }

        // Center intentionally empty — see the XY pad note; homing is global.

        AppButton {
            x: (parent.width - self.width) / 2;
            y: parent.height - self.height - 12px;
            width: 60px;
            height: 60px;
            icon: @image-url("assets/icons/arrow-down.svg");
            enabled: !root.busy;
            clicked => {
                root.move-z(-root.step-size)
            }
        }
    }

    // --- Rotation / Carriage Controller Section ---
    Rectangle {
        x: 610px;
        y: 116px;
        width: 110px;
        height: 232px;
        background: Theme.surface;
        border-color: Theme.border;
        border-width: 1px;
        border-radius: Theme.radius;
        AppButton {
            x: (parent.width - self.width) / 2;
            y: 12px;
            width: 60px;
            height: 60px;
            icon: @image-url("assets/icons/arrow-up.svg");
            enabled: !root.busy;
            clicked => {
                root.move-cart(root.step-size)
            }
        }

        AppButton {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 60px;
            height: 60px;
            icon: @image-url("assets/icons/home.svg");
            enabled: !root.busy;
            clicked => {
                root.home-cart()
            }
        }

        AppButton {
            x: (parent.width - self.width) / 2;
            y: parent.height - self.height - 12px;
            width: 60px;
            height: 60px;
            icon: @image-url("assets/icons/arrow-down.svg");
            enabled: !root.busy;
            clicked => {
                root.move-cart(-root.step-size)
            }
        }
    }

    // --- Footer ---
    // "Home all (G28)" is a motion action, "Ok" is navigation, so they sit in
    // opposite bottom corners (action left, leave right) — clearly not a pair.
    // Global homing is clearly labeled so it is not read as a per-axis action
    // either (#16).
    AppButton {
        x: 20px;
        y: parent.height - self.height - 15px;
        width: 200px;
        height: 60px;
        icon: @image-url("assets/icons/home.svg");
        text: @tr("Home all (G28)");
        enabled: !root.busy;
        clicked => {
            root.home-xyz()
        }
    }

    AppButton {
        x: parent.width - self.width - 20px;
        y: parent.height - self.height - 15px;
        width: 160px;
        height: 60px;
        primary: true;
        text: @tr("Ok");
        clicked => {
            root.ok-clicked()
        }
    }
}
