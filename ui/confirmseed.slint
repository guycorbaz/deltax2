// Confirm Seed Screen
// Step 2 of the seeding flow: Asks the user to load seeds into the hopper/robot
// before starting the automated process.

import { AppButton } from "widgets.slint";
import { Theme } from "theme.slint";

export component ConfirmSeed inherits Rectangle {
    background: Theme.bg;

    // Callbacks for navigation.
    callback cancel-clicked(); // Return to home screen
    callback ok-clicked();     // Final confirmation, start seeding process

    // Instruction Title
    Text {
        text: @tr("Load the seeds");
        y: 30px;
        font-size: Theme.font-title;
        font-weight: 700;
        color: Theme.text;
        horizontal-alignment: center;
        width: parent.width;
    }

    // Reference image of seeds
    Image {
        width: 250px;
        x: parent.width - self.width - 20px;
        y: (parent.height - self.height) / 2;
        source: @image-url("assets/images/graines.png");
    }

    // --- Action Buttons ---
    // Footer convention across all screens: the confirm button (Ok, primary) is
    // anchored to the bottom-right corner; Cancel sits immediately to its left
    // with a small gap (30px), so the pair stays together but Ok is always in
    // the same corner.
    AppButton {
        x: parent.width - 370px; // 20 right margin + 160 (Ok) + 30 gap + 160 (self)
        y: parent.height - self.height - 15px;
        width: 160px;
        height: 60px;
        text: @tr("Cancel");
        icon: @image-url("assets/icons/close.svg");
        clicked => {
            root.cancel-clicked()
        }
    }

    AppButton {
        x: parent.width - self.width - 20px;
        y: parent.height - self.height - 15px;
        width: 160px;
        height: 60px;
        primary: true;
        text: @tr("Ok");
        clicked => {
            root.ok-clicked()
        }
    }
}
