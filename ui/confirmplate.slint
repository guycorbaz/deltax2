// Confirm Plate Screen
// Step 1 of the seeding flow: Asks the user to physically install a seeding plate
// and select the corresponding layout from a list.
//
// Adding a tray type is documented as a config-only change, so the list must cope
// with any number of [[plates]] entries. It is laid out as a fixed 2x3 grid with
// pagination (issue #14): buttons stay >=60px for gloved touch and every plate is
// reachable without scrolling (kiosk rule: no scroll-only access to actions).

import { AppButton } from "widgets.slint";
import { Theme } from "theme.slint";

export component ConfirmPlate inherits Rectangle {
    background: Theme.bg;

    // List of available plate names, populated from the configuration in the backend.
    in property <[string]> plate-names;

    // Callbacks to notify the Rust backend.
    callback cancel-clicked();      // Return to home screen
    callback plate-selected(int);   // Confirm selected plate index and proceed

    // Pagination state. The grid shows `per-page` plates at a time; `current-page`
    // is 0-based and clamped implicitly by the Prev/Next enabled guards below.
    property <int> per-page: 6;     // 2 columns x 3 rows
    property <int> page-count: Math.max(1, Math.ceil(root.plate-names.length / root.per-page));
    property <int> current-page: 0;

    // Title instruction
    Text {
        text: @tr("Install the seeding plate");
        y: 30px;
        font-size: Theme.font-title;
        font-weight: 700;
        color: Theme.text;
        horizontal-alignment: center;
        width: parent.width;
    }

    // Visual reference for the user (sample image of paper pots)
    Image {
        x: 460px;
        y: (parent.height - self.height) / 2;
        width: 300px;
        source: @image-url("assets/images/paperpot.jpg");
    }

    // Plate selection grid + pager, occupying the left column. Anchored near
    // the top (not vertically centered) and sized to 276px so the pager clears
    // the footer within the 440px content area, even on a full second page.
    Rectangle {
        x: 41px;
        width: 344px;
        height: 276px;
        y: 64px;

        // One button per plate, but only those on the current page are shown.
        // Positioned on a 2-column grid: column pitch 184px (160 button + 24 gap),
        // row pitch 72px (60 + 12). Off-page buttons are hidden (and thus untappable).
        for name[i] in root.plate-names: AppButton {
            property <int> local-index: i - root.current-page * root.per-page;
            visible: local-index >= 0 && local-index < root.per-page;
            x: Math.mod(local-index, 2) * 184px;
            y: Math.floor(local-index / 2) * 72px;
            width: 160px;
            height: 60px;
            text: name;
            icon: @image-url("assets/icons/keypad.svg");
            clicked => {
                root.plate-selected(i)
            }
        }

        // Pager, only shown when the plates span more than one page.
        if root.page-count > 1: AppButton {
            x: 0px;
            y: 216px;
            width: 100px;
            height: 60px;
            text: @tr("Previous");
            enabled: root.current-page > 0;
            clicked => {
                root.current-page -= 1;
            }
        }
        if root.page-count > 1: Text {
            x: 100px;
            y: 216px;
            width: 144px;
            height: 60px;
            text: "\{root.current-page + 1} / \{root.page-count}";
            font-size: Theme.font-heading;
            font-weight: 700;
            color: Theme.text;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        if root.page-count > 1: AppButton {
            x: 244px;
            y: 216px;
            width: 100px;
            height: 60px;
            text: @tr("Next");
            enabled: root.current-page < root.page-count - 1;
            clicked => {
                root.current-page += 1;
            }
        }
    }

    // Navigation Footer — anchored to the bottom-right corner, the shared
    // position for a screen's confirm/leave button (the plate image clears it).
    AppButton {
        x: parent.width - self.width - 20px;
        y: parent.height - self.height - 15px;
        width: 160px;
        height: 60px;
        text: @tr("Cancel");
        icon: @image-url("assets/icons/close.svg");
        clicked => {
            root.cancel-clicked()
        }
    }
}
