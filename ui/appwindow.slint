// Main entry point for the DeltaX2 UI.
// This file defines the AppWindow which acts as the main container and navigator 
// for all screens in the application.

import { Theme } from "theme.slint";
import { AppButton } from "widgets.slint";
import { MainScreen } from "mainscreen.slint";
import { CalibrationScreen } from "calibrationscreen.slint";
import { SystemScreen } from "systemscreen.slint";
import { ConfirmPlate } from "confirmplate.slint";
import { ConfirmSeed } from "confirmseed.slint";
import { SeedingScreen } from "seedingscreen.slint";

// Defines the possible navigation states of the application.
export enum ScreenState {
    Main,           // Initial home screen
    Calibration,    // Manual jog and homing screen
    Configuration,  // Serial port and system settings
    ConfirmPlate,   // Step 1 of seeding: Select plate type
    ConfirmSeed,    // Step 2 of seeding: Final confirmation
    Seeding         // Active seeding process display
}

// Status codes pushed by the Rust backend instead of raw English strings, so
// the status bar text is produced by @tr on the UI side and gets translated
// (issue #18). Any dynamic part (a port name, an error detail, a plate name)
// travels separately in `status-arg`; the enum only selects the template.
export enum StatusKind {
    Initializing,       // no arg
    Connecting,         // no arg — initial/implicit connection
    ConnectingTo,       // arg: port name
    Connected,          // no arg
    ConnectionFailed,   // arg: "<port>: <detail>"
    MoveOk,             // no arg
    MoveError,          // arg: detail
    CartError,          // arg: detail
    Homing,             // no arg
    HomingComplete,     // no arg
    HomingError,        // arg: detail
    CartHomingError,    // arg: detail
    ConfigError,        // arg: detail
    SelectedPlate,      // arg: plate name
    NoPlateSelected,    // no arg
    Stopping,           // no arg
    SeedingPlate,       // arg: plate name
    SeedingComplete,    // no arg
    SeedingStopped,     // no arg
    SeedingFailed,      // no arg — short status; full detail goes to the banner
    SeedingPaused,      // no arg
    SeedingResumed,     // no arg
    Empty               // no arg — cleared status
}

// Codes for the persistent modal error banner, same rationale as StatusKind.
export enum ErrorKind {
    None,           // no banner
    WorkerDead,     // no arg — fixed operator message
    SeedingFailed   // arg: failure detail
}

// Global window component. It handles screen switching and bridges Rust callbacks to UI components.
export component AppWindow inherits Window {
    title: "DeltaX2";
    width: 800px;   // Native resolution for 7'' RPi touch screen
    height: 480px;  // Native resolution for 7'' RPi touch screen
    background: Theme.bg;
    
    // Kiosk mode for Raspberry Pi touchscreens.
    // When true, no-frame hides the OS title bar and borders.
    in-out property <bool> kiosk-mode: false;
    no-frame: root.kiosk-mode;

    // Tracks the currently displayed screen.
    in-out property <ScreenState> current-screen: ScreenState.Main;

    // Status surface. The backend sets a code (+ optional dynamic arg); the
    // displayed text is produced here with @tr so it is translated (issue #18).
    in-out property <StatusKind> status-kind: StatusKind.Initializing;
    in-out property <string> status-arg: "";
    // Derived, translated status line — read by the status bar and the
    // Configuration screen. Kept as a property named `status-text` so readers
    // are unchanged.
    property <string> status-text: root.status-line(root.status-kind, root.status-arg);
    in-out property <bool> is-connected: false;

    // Persistent, full-text error surface for failures needing operator action
    // (worker death, a seeding job that died mid-plate). Distinct from the
    // transient, elided status bar. A non-None code raises a modal banner; the
    // Dismiss button clears it. See the Slint rules in project-context.md.
    in-out property <ErrorKind> error-kind: ErrorKind.None;
    in-out property <string> error-arg: "";
    property <string> error-text: root.error-line(root.error-kind, root.error-arg);

    // Maps a status code (+ dynamic arg) to the translated line shown to the
    // operator. Templates live here so translators reach them through @tr.
    pure function status-line(kind: StatusKind, arg: string) -> string {
        if (kind == StatusKind.Initializing) { return @tr("Initializing..."); }
        if (kind == StatusKind.Connecting) { return @tr("Connecting..."); }
        if (kind == StatusKind.ConnectingTo) { return @tr("Connecting to {}...", arg); }
        if (kind == StatusKind.Connected) { return @tr("Connected"); }
        if (kind == StatusKind.ConnectionFailed) { return @tr("Connection failed — {}", arg); }
        if (kind == StatusKind.MoveOk) { return @tr("Move OK"); }
        if (kind == StatusKind.MoveError) { return @tr("Error: {}", arg); }
        if (kind == StatusKind.CartError) { return @tr("Error moving Cart: {}", arg); }
        if (kind == StatusKind.Homing) { return @tr("Homing..."); }
        if (kind == StatusKind.HomingComplete) { return @tr("Homing complete"); }
        if (kind == StatusKind.HomingError) { return @tr("Error homing XYZ: {}", arg); }
        if (kind == StatusKind.CartHomingError) { return @tr("Error homing Cart: {}", arg); }
        if (kind == StatusKind.ConfigError) { return @tr("Config error: {}", arg); }
        if (kind == StatusKind.SelectedPlate) { return @tr("Selected plate: {}", arg); }
        if (kind == StatusKind.NoPlateSelected) { return @tr("No plate selected"); }
        if (kind == StatusKind.Stopping) { return @tr("Stopping..."); }
        if (kind == StatusKind.SeedingPlate) { return @tr("Seeding plate: {}", arg); }
        if (kind == StatusKind.SeedingComplete) { return @tr("Seeding complete"); }
        if (kind == StatusKind.SeedingStopped) { return @tr("Seeding stopped"); }
        if (kind == StatusKind.SeedingFailed) { return @tr("Seeding failed"); }
        if (kind == StatusKind.SeedingPaused) { return @tr("Seeding paused"); }
        if (kind == StatusKind.SeedingResumed) { return @tr("Seeding resumed"); }
        return "";
    }

    pure function error-line(kind: ErrorKind, arg: string) -> string {
        if (kind == ErrorKind.WorkerDead) {
            return @tr("Robot control has stopped unexpectedly. Restart the application — the robot cannot be controlled until then.");
        }
        if (kind == ErrorKind.SeedingFailed) { return @tr("Seeding failed: {}", arg); }
        return "";
    }

    // True while a calibration command (jog or homing) is being executed by
    // the worker. The Calibration screen disables its motion buttons while set,
    // so a rapid tapper cannot queue an unbounded backlog of moves that keeps
    // the robot going long after they stop (issue #13). The worker clears it
    // when the command completes (see push_position in main.rs).
    in-out property <bool> jog-busy: false;

    // Real-time robot head position (tracked by the backend).
    in-out property <string> head-x: "0.000";
    in-out property <string> head-y: "0.000";
    in-out property <string> head-z: "0.000";
    in-out property <string> head-cart: "0.000";

    // Callbacks to be handled by the Rust backend.
    callback move-x(float);       // Relative move on X axis
    callback move-y(float);       // Relative move on Y axis
    callback move-z(float);       // Relative move on Z axis
    callback move-cart(float);    // Relative move on rotation axis
    callback home-xyz();          // Trigger G28 auto-homing
    callback home-cart();         // Reset carriage position

    // Serial port management (Configuration screen). The port list is shown
    // on screen — never on stdout, which is invisible in kiosk mode.
    in property <[string]> com-ports;      // Detected ports (incl. the config port), set by the backend
    in-out property <string> selected-port; // Port the operator picked; reconnect targets it
    callback refresh-com-ports();          // Re-enumerate serial ports into com-ports
    callback reconnect();                  // Re-run the connect handshake on selected-port
    in property <[string]> plate-names; // List of plate names from config.toml
    callback plate-selected(int);  // User selected a plate index (records the choice only)
    callback start-seeding();      // User confirmed seeds are loaded; begin the plate job
    callback stop-seeding();       // Abort the running seeding job
    callback pause-seeding();      // Suspend the seeding job before the next pot
    callback continue-seeding();   // Resume a paused seeding job

    // Progress of the running seeding job as raw counts (issue #18): the
    // backend pushes numbers, the SeedingScreen formats them with @tr so the
    // "Pot X / Y" template is translatable. `pot-total == 0` means the job is
    // starting (no pot processed yet).
    in-out property <int> pot-done: 0;
    in-out property <int> pot-total: 0;

    // Seeding pause state (issue #17). `seeding-paused` is the worker-confirmed
    // state: true only once the seeding loop has actually parked on a pause
    // between pots. `seeding-transition` is the pending state between the button
    // tap and that confirmation (the current pot must finish first), so the
    // Pause/Continue buttons can show a non-committed "pausing…/resuming…" state.
    in-out property <bool> seeding-paused: false;
    in-out property <bool> seeding-transition: false;

    VerticalLayout {
        // Content Area: Dynamically switches between sub-screens based on current-screen state.
        Rectangle {
            // Home Screen logic
            if (root.current-screen == ScreenState.Main): MainScreen {
                seed-clicked => {
                    root.current-screen = ScreenState.ConfirmPlate
                }
                calibration-clicked => {
                    root.current-screen = ScreenState.Calibration
                }
                configuration-clicked => {
                    root.current-screen = ScreenState.Configuration
                }
            }

            // Calibration & Manual Jog Screen logic
            if (root.current-screen == ScreenState.Calibration): CalibrationScreen {
                head-x: root.head-x;
                head-y: root.head-y;
                head-z: root.head-z;
                head-cart: root.head-cart;
                busy: root.jog-busy;
                ok-clicked => {
                    root.current-screen = ScreenState.Main
                }
                // Each motion sets the pending flag synchronously so the buttons
                // disable before the next tap can be registered; the worker
                // clears it when the command finishes.
                move-x(v) => {
                    root.jog-busy = true;
                    root.move-x(v);
                }
                move-y(v) => {
                    root.jog-busy = true;
                    root.move-y(v);
                }
                move-z(v) => {
                    root.jog-busy = true;
                    root.move-z(v);
                }
                move-cart(v) => {
                    root.jog-busy = true;
                    root.move-cart(v);
                }
                home-xyz => {
                    root.jog-busy = true;
                    root.home-xyz();
                }
                home-cart => {
                    root.jog-busy = true;
                    root.home-cart();
                }
            }

            // System Configuration Screen logic
            if (root.current-screen == ScreenState.Configuration): SystemScreen {
                com-ports: root.com-ports;
                selected-port <=> root.selected-port;
                is-connected: root.is-connected;
                status-text: root.status-text;
                ok-clicked => {
                    root.current-screen = ScreenState.Main
                }
                refresh-clicked => {
                    root.refresh-com-ports()
                }
                reconnect-clicked => {
                    root.reconnect()
                }
            }

            // Seeding Flow: Plate selection
            if (root.current-screen == ScreenState.ConfirmPlate): ConfirmPlate {
                plate-names: root.plate-names;
                cancel-clicked => {
                    root.current-screen = ScreenState.Main
                }
                plate-selected(id) => {
                    root.plate-selected(id);
                    root.current-screen = ScreenState.ConfirmSeed;
                }
            }

            // Seeding Flow: Confirmation. The robot job starts only here,
            // after the user confirmed that the seeds are loaded.
            if (root.current-screen == ScreenState.ConfirmSeed): ConfirmSeed {
                cancel-clicked => {
                    root.current-screen = ScreenState.Main
                }
                ok-clicked => {
                    root.start-seeding();
                    root.current-screen = ScreenState.Seeding;
                }
            }

            // Seeding Flow: Active Process
            if (root.current-screen == ScreenState.Seeding): SeedingScreen {
                pot-done: root.pot-done;
                pot-total: root.pot-total;
                paused: root.seeding-paused;
                transition: root.seeding-transition;
                stop-clicked => {
                    root.stop-seeding();
                    root.current-screen = ScreenState.Main;
                }
                pause-clicked => {
                    // Optimistic pending state until the worker confirms the
                    // pause took effect between pots (async-feedback rule).
                    root.seeding-transition = true;
                    root.pause-seeding();
                }
                continue-clicked => {
                    root.seeding-transition = true;
                    root.continue-seeding();
                }
            }
        }

        // Global status bar (app bar) at the bottom of the window.
        Rectangle {
            height: 44px;
            background: Theme.appbar;
            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 10px;
                alignment: start;

                // Connection status LED
                Rectangle {
                    width: 12px;
                    height: 12px;
                    border-radius: 6px;
                    background: root.is-connected ? Theme.ok : Theme.danger;
                    y: (parent.height - self.height) / 2;
                }

                // Connection text label
                Text {
                    text: root.is-connected ? @tr("Connected") : @tr("Disconnected");
                    color: Theme.appbar-text;
                    font-size: Theme.font-body;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: 20px;
                } // Spacer

                // Detailed status message (e.g., "Ready", "Error: ...", "Seeding complete")
                Text {
                    text: root.status-text;
                    color: Theme.appbar-text-muted;
                    font-size: Theme.font-body;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }

    // Modal error banner, rendered above every screen (sibling of the layout,
    // so it is not constrained by it). Shown only when an error code is set:
    // full word-wrapped text and a Dismiss action, over a backdrop that
    // swallows touches so the underlying UI cannot be operated until the
    // operator acknowledges the failure.
    if (root.error-kind != ErrorKind.None): Rectangle {
        width: root.width;
        height: root.height;
        background: #0b120ecc;

        // Swallow touches on the backdrop so controls underneath stay inert.
        TouchArea { }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 620px;
            height: 300px;
            background: Theme.surface;
            border-radius: Theme.radius;
            border-width: 2px;
            border-color: Theme.danger;
            drop-shadow-blur: 24px;
            drop-shadow-color: #00000066;

            VerticalLayout {
                padding: 28px;
                spacing: 18px;

                Text {
                    text: @tr("Error");
                    color: Theme.danger;
                    font-size: Theme.font-title;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.error-text;
                    color: Theme.text;
                    font-size: Theme.font-heading;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    vertical-stretch: 1;
                }
                AppButton {
                    primary: true;
                    text: @tr("Dismiss");
                    clicked => {
                        root.error-kind = ErrorKind.None;
                    }
                }
            }
        }
    }
}
