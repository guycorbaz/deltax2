// Calibration Screen
// This screen allows the user to manually control the robot's movement (jogging)
// and perform homing operations for all axes.

import { Button } from "std-widgets.slint";

export component CalibrationScreen inherits Rectangle {
    background: #c2c2c2;

    // Head position properties received from the backend (for display only).
    in-out property <string> head-x: "0.000";
    in-out property <string> head-y: "0.000";
    in-out property <string> head-z: "0.000";
    in-out property <string> head-cart: "0.000";
    
    // The amount the robot moves on each button click.
    in-out property <float> step-size: 0.01;

    // True while a jog/homing command is running on the worker. Motion buttons
    // disable themselves so taps cannot pile up faster than the robot executes
    // them (issue #13); the step-size and Ok buttons stay usable.
    in property <bool> busy;

    // Callbacks to notify the Rust backend of user interactions.
    callback ok-clicked();
    callback move-x(float);
    callback move-y(float);
    callback move-z(float);
    callback move-cart(float);
    callback home-xyz();
    callback home-cart();

    // --- Position Readout Section (Top Right) ---
    Rectangle {
        x: 421px;
        y: 10px;
        width: 349px;
        height: 75px;
        Text {
            text: @tr("Position");
            y: 0px;
            width: parent.width;
            font-size: 14px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        Rectangle {
            y: 20px;
            width: parent.width;
            height: 50px;
            background: root.background;
            border-color: #929292;
            border-width: 1px;
            border-radius: 5px;
            Text {
                text: "X: " + root.head-x + "  Y: " + root.head-y + "  Z: " + root.head-z + "  Cart: " + root.head-cart;
                vertical-alignment: center;
                horizontal-alignment: center;
                font-weight: 700;
            }
        }
    }

    // --- Step Size Selection Section (Above XY Controls) ---
    Rectangle {
        x: 80px;
        y: 10px;
        width: 280px;
        height: 100px;
        Text {
            text: @tr("Step (mm)");
            y: 0px;
            width: parent.width;
            font-size: 14px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        // Step buttons. The active step is highlighted (primary/accent) so the
        // operator can tell whether the next jog moves 0.01mm or 5mm (#16). Each
        // button is 64px tall to meet the >=60px touch-target rule for gloved use.
        Button {
            x: 0px;
            y: 28px;
            width: 64px;
            height: 64px;
            text: "0.01";
            primary: root.step-size == 0.01;
            clicked => {
                root.step-size = 0.01;
            }
        }

        Button {
            x: 72px;
            y: 28px;
            width: 64px;
            height: 64px;
            text: "0.1";
            primary: root.step-size == 0.1;
            clicked => {
                root.step-size = 0.1;
            }
        }

        Button {
            x: 144px;
            y: 28px;
            width: 64px;
            height: 64px;
            text: "1";
            primary: root.step-size == 1.0;
            clicked => {
                root.step-size = 1.0;
            }
        }

        Button {
            x: 216px;
            y: 28px;
            width: 64px;
            height: 64px;
            text: "5";
            primary: root.step-size == 5.0;
            clicked => {
                root.step-size = 5.0;
            }
        }
    }

    // --- XY Controller Section ---
    Text {
        x: 80px + (280px - self.width) / 2;
        y: 125px;
        text: "Y";
        font-size: 14px;
        font-weight: 700;
    }

    Text {
        x: 80px - self.width - 10px;
        y: 150px + (240px - self.height) / 2;
        text: "X";
        font-size: 14px;
        font-weight: 700;
    }

    Rectangle {
        x: 80px;
        y: 150px;
        width: 280px;
        height: 240px;
        border-color: #929292;
        border-width: 1px;
        border-radius: 5px;
        Button {
            x: (parent.width - self.width) / 2;
            y: 10px;
            width: 65px;
            height: 65px;
            icon: @image-url("assets/icons/arrow-up.svg");
            enabled: !root.busy;
            clicked => {
                root.move-y(root.step-size)
            }
        }

        Button {
            x: 10px;
            y: (parent.height - self.height) / 2;
            width: 65px;
            height: 65px;
            icon: @image-url("assets/icons/arrow-left.svg");
            enabled: !root.busy;
            clicked => {
                root.move-x(-root.step-size)
            }
        }

        // Center is intentionally empty: homing is global (G28) and lives in a
        // clearly labeled footer button, not inside a single-axis pad (#16).
        // It doubles as the "move in progress" indicator (issue #13).
        Text {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            text: @tr("Moving…");
            color: #8a5a00;
            font-size: 14px;
            font-weight: 700;
            visible: root.busy;
        }

        Button {
            x: parent.width - self.width - 10px;
            y: (parent.height - self.height) / 2;
            width: 65px;
            height: 65px;
            icon: @image-url("assets/icons/arrow-right.svg");
            enabled: !root.busy;
            clicked => {
                root.move-x(root.step-size)
            }
        }

        Button {
            x: (parent.width - self.width) / 2;
            y: parent.height - self.height - 10px;
            width: 65px;
            height: 65px;
            icon: @image-url("assets/icons/arrow-down.svg");
            enabled: !root.busy;
            clicked => {
                root.move-y(-root.step-size)
            }
        }
    }

    // --- Z Axis Controller Section ---
    Text {
        x: 437px + (110px - self.width) / 2;
        y: 125px;
        text: "Z";
        font-size: 14px;
        font-weight: 700;
    }

    Rectangle {
        x: 437px;
        y: 150px;
        width: 110px;
        height: 240px;
        border-color: #929292;
        border-width: 1px;
        border-radius: 5px;
        Button {
            x: (parent.width - self.width) / 2;
            y: 10px;
            width: 65px;
            height: 65px;
            icon: @image-url("assets/icons/arrow-up.svg");
            enabled: !root.busy;
            clicked => {
                root.move-z(root.step-size)
            }
        }

        // Center intentionally empty — see the XY pad note; homing is global.

        Button {
            x: (parent.width - self.width) / 2;
            y: parent.height - self.height - 10px;
            width: 65px;
            height: 65px;
            icon: @image-url("assets/icons/arrow-down.svg");
            enabled: !root.busy;
            clicked => {
                root.move-z(-root.step-size)
            }
        }
    }

    // --- Rotation / Carriage Controller Section ---
    Text {
        x: 610px + (110px - self.width) / 2;
        y: 125px;
        text: "Cart";
        font-size: 14px;
        font-weight: 700;
    }

    Rectangle {
        x: 610px;
        y: 150px;
        width: 110px;
        height: 240px;
        border-color: #929292;
        border-width: 1px;
        border-radius: 5px;
        Button {
            x: (parent.width - self.width) / 2;
            y: 10px;
            width: 65px;
            height: 65px;
            icon: @image-url("assets/icons/arrow-up.svg");
            enabled: !root.busy;
            clicked => {
                root.move-cart(root.step-size)
            }
        }

        Button {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 65px;
            height: 65px;
            icon: @image-url("assets/icons/home.svg");
            enabled: !root.busy;
            clicked => {
                root.home-cart()
            }
        }

        Button {
            x: (parent.width - self.width) / 2;
            y: parent.height - self.height - 10px;
            width: 65px;
            height: 65px;
            icon: @image-url("assets/icons/arrow-down.svg");
            enabled: !root.busy;
            clicked => {
                root.move-cart(-root.step-size)
            }
        }
    }

    // --- Navigation Footer ---
    // Global homing lives here, clearly labeled, so it can no longer be mistaken
    // for a per-axis action inside an axis pad (#16). G28 homes all axes to the top.
    Button {
        x: 80px;
        y: parent.height - self.height - 15px;
        width: 220px;
        height: 60px;
        icon: @image-url("assets/icons/home.svg");
        text: @tr("Home all (G28)");
        enabled: !root.busy;
        clicked => {
            root.home-xyz()
        }
    }

    Button {
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 15px;
        width: 160px;
        height: 60px;
        text: @tr("Ok");
        clicked => {
            root.ok-clicked()
        }
    }
}
